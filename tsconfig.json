{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node", "bun"],
    "baseUrl": ".",
    "paths": {
      "src/*": ["./*"],
      "src//*": ["./*"],
      "src": ["./"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx", "globals.d.ts"],
  "exclude": ["node_modules", "dist"]
}
